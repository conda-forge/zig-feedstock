From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: conda-forge <conda-forge@users.noreply.github.com>
Date: Tue, 18 Mar 2026 00:00:00 +0000
Subject: [PATCH] link(ELF): handle relative paths and -l flags in GNU ld
 scripts

Implement the two TODO panics in loadGnuLdScript that crash when
processing GNU ld scripts containing:

1. Relative paths (e.g. "../lib64/libc_nonshared.a") - resolved
   relative to the directory containing the ld script.

2. -l flags (e.g. "-lpthread") - resolved by searching for
   lib<name>.so then lib<name>.a in the ld script's directory.

These patterns are common in glibc sysroots where linker scripts like
libc.so contain:
  GROUP ( /lib64/libc.so.6 /usr/lib64/libc_nonshared.a )
or libpthread.so contains:
  INPUT ( /usr/lib64/libpthread_nonshared.a -lpthread )

When paths are rewritten to relative (e.g. by conda-forge sysroot
fixups), the linker must resolve them against the script's location.

diff --git a/src/link.zig b/src/link.zig
--- a/src/link.zig
+++ b/src/link.zig
@@ -1060,7 +1060,30 @@
                 .allow_so_scripts = parent_query.allow_so_scripts,
             };
             if (mem.startsWith(u8, arg.path, "-l")) {
-                @panic("TODO");
+                // GNU ld script contains -l<name> flag.
+                // Search for lib<name>.so then lib<name>.a in the script's directory,
+                // consistent with GNU ld behavior for scripts.
+                const lib_name = arg.path[2..];
+                const script_dir = fs.path.dirname(path.sub_path) orelse "";
+                const sep: []const u8 = if (script_dir.len > 0) fs.path.sep_str else "";
+                const so_sub = try std.fmt.allocPrint(gpa, "{s}{s}lib{s}.so", .{ script_dir, sep, lib_name });
+                const so_path: Path = .{ .root_dir = path.root_dir, .sub_path = so_sub };
+                openLoadDso(base, so_path, query) catch |err| switch (err) {
+                    error.FileNotFound => {
+                        // .so not found, try static archive
+                        gpa.free(so_sub);
+                        const a_sub = try std.fmt.allocPrint(gpa, "{s}{s}lib{s}.a", .{ script_dir, sep, lib_name });
+                        const a_path: Path = .{ .root_dir = path.root_dir, .sub_path = a_sub };
+                        openLoadArchive(base, a_path, query) catch |archive_err| switch (archive_err) {
+                            error.FileNotFound => {
+                                gpa.free(a_sub);
+                                diags.addParseError(path, "GNU ld script references library not found: {s}", .{arg.path});
+                            },
+                            else => return archive_err,
+                        };
+                    },
+                    else => return err,
+                };
             } else {
                 if (fs.path.isAbsolute(arg.path)) {
                     const new_path = Path.initCwd(try gpa.dupe(u8, arg.path));
@@ -1071,7 +1094,16 @@
                         else => diags.addParseError(path, "GNU ld script references file with unrecognized extension: {s}", .{arg.path}),
                     }
                 } else {
-                    @panic("TODO");
+                    // Resolve relative path against the directory containing the ld script.
+                    const script_dir = fs.path.dirname(path.sub_path) orelse "";
+                    const resolved_sub = try fs.path.resolvePosix(gpa, &.{ script_dir, arg.path });
+                    const resolved_path: Path = .{ .root_dir = path.root_dir, .sub_path = resolved_sub };
+                    switch (Compilation.classifyFileExt(arg.path)) {
+                        .shared_library => try openLoadDso(base, resolved_path, query),
+                        .object => try openLoadObject(base, resolved_path),
+                        .static_library => try openLoadArchive(base, resolved_path, query),
+                        else => diags.addParseError(path, "GNU ld script references file with unrecognized extension: {s}", .{arg.path}),
+                    }
                 }
             }
         }
