+//! Shared libc++ discovery for conda-forge zig packaging.
+//! Probes for a shared libc++ library relative to zig_lib_dir,
+//! falling back to null (caller uses static libc++.a).
+
+const std = @import("std");
+const Allocator = std.mem.Allocator;
+const Cache = std.Build.Cache;
+const Compilation = @import("../Compilation.zig");
+
+/// Platform-specific shared library names for libc++.
+/// Keyed by target OS tag.
+fn sharedLibCxxNames(os_tag: std.Target.Os.Tag) []const []const u8 {
+    if (os_tag.isDarwin()) {
+        return &.{ "libc++.1.dylib", "libc++.dylib" };
+    }
+    return switch (os_tag) {
+        .linux, .freebsd, .netbsd, .openbsd, .dragonfly => &.{ "libc++.so.1", "libc++.so" },
+        .windows => &.{"libc++.dll.a"},
+        else => &.{},
+    };
+}
+
+/// Probe directories relative to zig_lib (which is <prefix>/lib/zig/).
+/// Two levels up reaches <prefix>/, then:
+///   - <prefix>/lib/zig-llvm/lib/  (preferred: dedicated zig-llvm package)
+///   - <prefix>/lib/                (fallback: standard lib dir)
+const probe_subdirs = [_][]const u8{
+    "../../lib/zig-llvm/lib",
+    "../../lib",
+};
+
+/// Find shared libc++ and return its path as a string (for argv-based linkers).
+/// Returns null if no shared libc++ found. Errors only on allocation failure.
+pub fn findSharedLibCxxString(comp: *const Compilation, arena: Allocator) !?[]const u8 {
+    const target = &comp.root_mod.resolved_target.result;
+    const names = sharedLibCxxNames(target.os.tag);
+    if (names.len == 0) return null;
+
+    const zig_lib_path = comp.dirs.zig_lib.path orelse return null;
+
+    for (&probe_subdirs) |subdir| {
+        for (names) |name| {
+            const probe = try std.fs.path.join(arena, &.{ zig_lib_path, subdir, name });
+            // Check if file exists via access()
+            std.fs.cwd().access(probe, .{}) catch continue;
+            return probe;
+        }
+    }
+    return null;
+}
+
+/// Find shared libc++ and return its Cache.Path (for MachO system_libs).
+/// Uses Cache.Path.initCwd() — probe string is absolute since zig_lib_path is absolute.
+/// Returns null if no shared libc++ found.
+pub fn findSharedLibCxxPath(comp: *const Compilation, arena: Allocator) !?Cache.Path {
+    const str = try findSharedLibCxxString(comp, arena) orelse return null;
+    return Cache.Path.initCwd(str);
+}
